# SearXNG++ Gateway Configuration
# Copy to .env and adjust values

# SearXNG upstream
GATEWAY_SEARXNG_URL=http://localhost:8888
GATEWAY_SEARXNG_TIMEOUT=10.0

# Crawl4AI internal service
GATEWAY_CRAWL_SERVICE_URL=http://localhost:11235
GATEWAY_CRAWL_SERVICE_PATH=/crawl
GATEWAY_CRAWL_SERVICE_TIMEOUT=20.0
GATEWAY_CRAWL_MAX_CONTENT_LENGTH=100000
GATEWAY_CRAWL_MAX_CONCURRENT=3

# Redis
GATEWAY_REDIS_URL=redis://localhost:6379/0

# Authentication (CHANGE THIS)
GATEWAY_AUTH_TOKEN=changeme-generate-a-secure-token

# Rate limiting
GATEWAY_RATE_LIMIT_RPM=60

# Content fetching
GATEWAY_CONTENT_FETCH_TIMEOUT=8.0
GATEWAY_MAX_CONTENT_LENGTH=50000
GATEWAY_ENABLE_BROWSER_FALLBACK=false

# Cache TTLs (seconds)
GATEWAY_CACHE_TTL=3600
GATEWAY_CONTENT_CACHE_TTL=86400
GATEWAY_DOMAIN_COOLDOWN_TTL=300

# Reranker weights (must sum to ~1.0)
GATEWAY_WEIGHT_LEXICAL=0.30
GATEWAY_WEIGHT_SEMANTIC=0.25
GATEWAY_WEIGHT_QUALITY=0.25
GATEWAY_WEIGHT_FRESHNESS=0.20
